{
  "name": "nodejs-mcp-server",
  "version": "1.0.0",
  "description": "A fully featured, simple Model Context Protocol (MCP) server demonstrating tools, resources, and prompts. No authentication. For testing and learning.",
  "type": "module",
  "bin": {
    "nodejs-mcp-server": "dist/stdio.js"
  },
  "scripts": {
    "build": "tsc",
    "build:vercel": "npm run build && npm run typecheck:vercel",
    "start": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "dev:stdio": "tsx watch src/stdio.ts",
    "dev:http": "tsx watch src/http.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/stdio.js",
    "test:smoke": "npm run build && node scripts/smoke.mjs",
    "test:vercel": "tsx scripts/smoke-vercel.ts",
    "typecheck:vercel": "tsc -p tsconfig.vercel.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "tools",
    "resources",
    "prompts",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
